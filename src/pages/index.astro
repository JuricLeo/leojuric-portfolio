---
import MainLayout from "@/layouts/main-layout.astro";

import Separator from "@/components/ui/separator.astro";

import Experience from "@/components/pages/home/experience.astro";
import Blogs from "@/components/pages/home/blogs.astro";
import Tools from "@/components/pages/home/tools.astro";
import Stats from "@/components/pages/home/stats.astro";
import Projects from "@/components/pages/home/projects.astro";
import Contact from "@/components/pages/home/contact.astro";

const title = "Leopold Jurić - Personal Portfolio & Blog";
const description =
    "👋 Hi! I'm Leopold Jurić, a web developer who still genuinely enjoys coding. I experiment with new tools, break things, fix them, and share what I learn. If there’s code to optimize, I’ll always try to squeeze more performance out of it.";

const openGraph = {
    title,
    description,
    url: "https://leopold-juric.com/",
};
---

<MainLayout title={title} description={description} openGraph={openGraph}>
    <Experience />
    <Separator />
    <Blogs />
    <Separator />
    <Tools />
    <Separator />
    <Stats />
    <Separator />
    <Projects />
    <Separator />
    <Contact />
</MainLayout>
