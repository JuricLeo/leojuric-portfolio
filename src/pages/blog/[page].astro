---
import "@/styles/content.css";

import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";

import MainLayout from "@/layouts/main-layout.astro";
import { formatDate } from "@/lib/utils.ts";

export const getStaticPaths = (async () => {
    const articles = await getCollection("articles");
    return articles
        .filter((article) => article.data.status === "ready")
        .map((article) => ({
            params: { page: article.id },
            props: { article },
        }));
}) satisfies GetStaticPaths;

const { article } = Astro.props;
const { Content } = await render(article);

const truncatedDescription =
    article.data.description && article.data.description.length > 155 ? article.data.description.substring(0, 152) + "..." : article.data.description;

const { title } = article.data;

const canonicalUrl = `https://leopold-juric.com/blog/${article.id}/`;

const openGraph = {
    title: `${title} | Leopold Jurić`,
    description: truncatedDescription,
    url: canonicalUrl,
    image: `https://leopold-juric.com/assets/images/blog/${article.id}/thumbnail.webp`,
};

const frontmatter = {
    ...article.data,
    id: article.id,
};

const articleJsonLd = {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: article.data.title,
    description: truncatedDescription,
    image: openGraph.image,
    datePublished: article.data.date.toISOString(),
    dateModified: article.data.date.toISOString(),
    author: {
        "@type": "Person",
        name: "Leopold Jurić",
    },
    publisher: {
        "@type": "Person",
        name: "Leopold Jurić",
        logo: {
            "@type": "ImageObject",
            url: "https://leopold-juric.com/assets/images/logo.webp",
        },
    },
    mainEntityOfPage: {
        "@type": "WebPage",
        "@id": canonicalUrl,
    },
};
---

<MainLayout title={title} description={truncatedDescription} openGraph={openGraph} frontmatter={frontmatter} canonical={canonicalUrl}>
    <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} is:inline />
    <article class="flex flex-col items-center w-full px-3" data-pagefind-body data-pagefind-filter="section:articles">
        <div class="flex mr-auto gap-2 mb-2 items-center" transition:name={`${article.id}-data`}>
            <p class="text-muted mt-1">{formatDate(article.data.date)}</p>
            <p class="bg-muted/10 px-2 py-0.5 text-sm">{article.data.category}</p>
        </div>
        <div class="flex flex-col gap-0 mx-auto flex-1 w-full">
            <h1 class="text-2xl font-bold" transition:name={`${article.id}-title`}>
                {article.data.title}
            </h1>
            <p class="text-muted text-base" transition:name={`${article.id}-description`}>{article.data.description}</p>
        </div>
        <div class="text-left w-full mt-12 mdx-content border-t border-dotted">
            <Content />
        </div>
    </article>
</MainLayout>
