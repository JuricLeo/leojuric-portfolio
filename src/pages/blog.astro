---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";

import MainLayout from "@/layouts/main-layout.astro";

export const getStaticPaths = (async () => {
    const articles = await getCollection("articles");
    return articles
        .filter((article) => article.data.status === "ready")
        .map((article) => ({
            params: { page: article.id },
            props: { article },
        }));
}) satisfies GetStaticPaths;

const { article } = Astro.props;
const { Content } = await render(article);

const truncatedDescription =
    article.data.description && article.data.description.length > 155 ? article.data.description.substring(0, 152) + "..." : article.data.description;

const { title } = article.data;

const canonicalUrl = `https://www.leopold-juric.com/blog/${article.id}`;

const openGraph = {
    title: `${title} | Leopold Jurić`,
    description: truncatedDescription,
    url: `https://www.leopold-juric.com/blog/${article.id}`,
    image: `https://www.leopold-juric.com/assets/images/blog/${article.id}/thumbnail.webp`,
};

const frontmatter = {
    ...article.data,
    id: article.id,
};

const articleJsonLd = {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: article.data.title,
    description: truncatedDescription,
    image: openGraph.image,
    datePublished: article.data.date.toISOString(),
    dateModified: article.data.date.toISOString(),
    author: {
        "@type": "Person",
        name: "Leopold Jurić",
    },
    publisher: {
        "@type": "Person",
        name: "Leopold Jurić",
        logo: {
            "@type": "ImageObject",
            url: "https://www.leopold-juric.com/assets/images/logo.webp",
        },
    },
    mainEntityOfPage: {
        "@type": "WebPage",
        "@id": canonicalUrl,
    },
};
---

<MainLayout title={title} description={truncatedDescription} openGraph={openGraph} frontmatter={frontmatter} canonical={canonicalUrl}>
    <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} is:inline />
    <div>
        <h1 class="text-3xl">blog</h1>
    </div>
</MainLayout>
