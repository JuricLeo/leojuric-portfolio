---
const { class: className = "", disabled = false, ...rest } = Astro.props;
---

<button
    disabled={disabled}
    class={`inline-flex items-center justify-center bg-black text-white border px-4 py-1.5 ${
        disabled ? "opacity-60" : "cursor-pointer hover:opacity-80 hover:-translate-y-0.5"
    } ${className}`}
    {...rest}
>
    <slot />
</button>
