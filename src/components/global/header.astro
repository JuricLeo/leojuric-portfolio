---
import { cn } from "@/lib/utils.ts";

import Logo from "@/components/global/logo.astro";
import Socials from "@/components/global/socials.astro";

import ListIcon from "@/assets/icons/content/list.svg";
import XIcon from "@/assets/icons/content/x.svg";

const routes = [
    {
        name: "Home",
        href: "/",
    },
    {
        name: "My Work",
        href: "/my-work/",
    },
    {
        name: "Blog",
        href: "/blog/",
    },
];

const normalizePath = (path: string) => {
    const noIndex = path.replace(/index\.html$/, "/");
    const noHtml = noIndex.replace(/\.html$/, "");
    const noTrailing = noHtml !== "/" ? noHtml.replace(/\/$/, "") : noHtml;
    return noTrailing || "/";
};

const pathname = normalizePath(Astro.url.pathname);
---

<header class="sticky top-0 z-30 mx-auto mb-12 flex h-12 w-full items-center justify-between gap-6 border-y border-dotted bg-background">
    <a href="/" aria-label="Go home" class="ml-3"> // Leopold Jurić </a>
    <nav aria-label="Main navigation" class="hidden h-full items-stretch sm:flex">
        {
            routes.map((route) => (
                <a
                    class={cn(
                        "flex h-full items-center border-x border-dotted px-6 font-bold text-muted hover:-translate-y-0.5 hover:text-primary",
                        pathname === route.href && "border-primary text-primary opacity-100"
                    )}
                    href={route.href}
                >
                    {route.name}
                </a>
            ))
        }
    </nav>

    <details class="group sm:hidden">
        <summary class="mr-9 mb-6 cursor-pointer list-none">
            <span class="sr-only">Open navigation menu</span>
            <ListIcon class="absolute size-6 opacity-100 transition-opacity duration-200 group-open:opacity-0" />
            <XIcon class="absolute size-6 opacity-0 transition-opacity duration-200 group-open:opacity-100" />
        </summary>
        <div class="fixed inset-0 top-12 flex h-screen flex-col bg-background">
            <nav class="flex flex-col gap-4 py-10 pl-10">
                {
                    routes.map((route) => (
                        <a
                            class={cn(
                                "text-3xl font-bold text-muted-foreground hover:text-primary hover:underline",
                                pathname === route.href && "text-primary"
                            )}
                            href={route.href}
                        >
                            {route.name}
                        </a>
                    ))
                }
            </nav>
            <footer class="mt-auto mb-20 flex w-full flex-col items-center justify-center gap-4">
                <Logo />
                <p class="block text-center text-sm text-muted-foreground">Leopold Jurić</p>
                <div class="flex gap-2">
                    <Socials />
                </div>
            </footer>
        </div>
    </details>
</header>
