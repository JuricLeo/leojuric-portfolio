---
import TechCard from "./tech-card.astro";
---

<section class="px-3 flex flex-col gap-10 xs:gap-6">
    <h1 class="text-3xl -mb-2">tools</h1>
    <div>
        <p class="text-muted">#frontend</p>
        <div class="flex flex-col xs:flex-row xs:items-center gap-2 ml-0.5">
            <TechCard tool="Astro" />
            <span class="hidden xs:block text-muted/50">/</span>
            <TechCard tool="React" />
            <span class="hidden xs:block text-muted/50">/</span>
            <TechCard tool="Tailwind CSS" />
        </div>
    </div>
    <div>
        <p class="text-muted">#backend</p>
        <div class="flex flex-col xs:flex-row xs:items-center gap-2 ml-0.5">
            <TechCard tool="Laravel" />
            <span class="hidden xs:block text-muted/50">/</span>
            <TechCard tool="PostgreSQL" />
            <span class="hidden xs:block text-muted/50">/</span>
            <TechCard tool="Bun" />
        </div>
    </div>
    <div>
        <p class="text-muted">#devops</p>
        <div class="flex flex-col xs:flex-row xs:items-center gap-2 ml-0.5">
            <TechCard tool="Docker" />
            <span class="hidden xs:block text-muted/50">/</span>
            <TechCard tool="Pest" />
            <span class="hidden xs:block text-muted/50">/</span>
            <TechCard tool="Vitest" />
        </div>
    </div>
    <div>
        <p class="text-muted">#design</p>
        <div class="flex flex-col xs:flex-row xs:items-center gap-2 ml-0.5">
            <TechCard tool="Affinity" />
            <span class="hidden xs:block text-muted/50">/</span>
            <TechCard tool="Figma" />
            <span class="hidden xs:block text-muted/50">/</span>
            <TechCard tool="DaVinci Resolve" />
        </div>
    </div>
</section>
