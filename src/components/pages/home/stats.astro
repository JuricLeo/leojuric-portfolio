---

<section class="px-3">
    <h1 class="text-3xl mb-4">github stats</h1>
    <div>
        <div class="flex items-center gap-2">
            <img class="size-5" alt="git-merge" src="/assets/icons/content/git-merge.svg" />
            <!-- https://github.com/pulls?page=1&q=is%3Apr+author%3AJuricLeo+archived%3Afalse+is%3Amerged -->
            <p class="flex">
                <span class="text-muted xxs:min-w-68">Merged PRs:</span>
                <span class="ml-1">550+</span>
            </p>
        </div>
        <div class="flex items-center gap-2">
            <img class="size-5" alt="git-commit" src="/assets/icons/content/git-commit.svg" />
            <!-- https://github.com/JuricLeo -->
            <p class="flex">
                <span class="text-muted xxs:min-w-68">Contributions last year:</span>
                <span class="ml-1">2200+</span>
            </p>
        </div>
        <div class="flex items-center gap-2">
            <img class="size-5" alt="folder-open" src="/assets/icons/content/folder-open.svg" />
            <p class="flex">
                <span class="text-muted xxs:min-w-68">Projects:</span>
                <span class="ml-1">25+</span>
            </p>
        </div>
    </div>
</section>
