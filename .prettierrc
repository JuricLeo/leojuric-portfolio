{
    "endOfLine": "lf",
    "semi": true,
    "singleQuote": false,
    "tabWidth": 4,
    "trailingComma": "es5",
    "printWidth": 150,
    "plugins": ["prettier-plugin-astro", "prettier-plugin-tailwindcss"],
    "tailwindStylesheet": "src/styles/global.css",
    "tailwindFunctions": ["cn", "cva"],
    "overrides": [
        {
            "files": "*.astro",
            "options": {
                "parser": "astro"
            }
        }
    ]
}
